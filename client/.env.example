# Copy this to .env.local for local development
# In production (Vercel), set these in the Vercel dashboard → Settings → Environment Variables

# URL of your backend API
# Local: leave empty or set to http://localhost:4000
# Vercel: set to your Vercel deployment URL e.g. https://sellbazar.vercel.app
VITE_API_URL=

# Image uploads use ImgBB (https://api.imgbb.com) — no extra config needed.
# The API key is set directly in client/src/composables/useAdminApi.ts (IMGBB_API_KEY).
# Max image size: 25 MB per file.

# (Server-side — set in Vercel dashboard, NOT here)
# JWT_SECRET=your-secret-here
# ALLOWED_ORIGINS=https://sellbazar.vercel.app
