# SellBazar — environment variables
# Copy to .env for local dev. Set these in the Vercel dashboard for production.

# Neon Serverless Postgres (required)
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT signing secret (change this to a random 32+ char string in production)
JWT_SECRET=your-secret-here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://sell-bazar.vercel.app

# ImgBB image upload API key
# Get from: https://api.imgbb.com → Account → API key
IMGBB_API_KEY=your-imgbb-api-key-here
